{
  "$schema": "https://opencode.ai/config.json",
  "formatter": true,
  "lsp": true,
  "permission": {
    "bash": {
      "git add *": "ask",  
      "git commit *": "ask",
      "rm *": "ask"
    }
  },
  "skills": {
    "git-commit-guide": {
      "enabled": true,
      "path": ".agents/skills/git-commit-guide"
    },
    "frontend-design": {
      "enabled": true,
      "path": ".agents/skills/frontend-design"
    },
    "review-architecture-project": {
      "enabled": true,
      "path": ".agents/skills/review-architecture-project"
    }
  },
  "mcp": {
    "next-devtools": {
      "type": "local",
      "command": ["npx", "-y", "next-devtools-mcp@latest"],
      "enabled": true,
    },
  },
}